---
interface Props {
    title: string;
    description: string;
    image?: string;
    type?: "website" | "article";
    publishDate?: Date;
}

const {
    title,
    description,
    image,
    type = "website",
    publishDate,
} = Astro.props;

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = "r3d/ops — KBM Security";
const ogImage = image
    ? new URL(image.startsWith("/") ? image : `/${image}`, Astro.site)
    : null;
---

<!-- Charset & Viewport -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />

<!-- Favicon (SVG only — safest cross-browser approach for static sites) -->
<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- Theme -->
<meta name="theme-color" content="#0a0a0a" />
<meta name="color-scheme" content="dark" />

<!-- Primary SEO -->
<title>{title}</title>
<meta name="description" content={description} />
<meta
    name="keywords"
    content="red team, pentest, offensive security, hacking, OSINT, privilege escalation, evasion, lateral movement, KBM Security"
/>
<meta name="author" content="KBM Security" />
<meta name="robots" content="index, follow" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{ogImage && <meta property="og:image" content={ogImage} />}
{ogImage && <meta property="og:image:alt" content={title} />}
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="pt_BR" />
{
    type === "article" && publishDate && (
        <meta
            property="article:published_time"
            content={publishDate.toISOString()}
        />
    )
}

<!-- Twitter / X -->
<meta
    name="twitter:card"
    content={ogImage ? "summary_large_image" : "summary"}
/>
<meta name="twitter:site" content="@kbmsecurity" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

<!-- RSS Feed -->
<link
    rel="alternate"
    type="application/rss+xml"
    title={`${siteName} RSS Feed`}
    href={`${base}feed.xml`}
/>

<!-- Fonts — JetBrains Mono via Google Fonts (preconnect first for perf) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
    href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap"
    rel="stylesheet"
/>

<!-- Structured data -->
<script
    type="application/ld+json"
    set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": type === "article" ? "Article" : "WebSite",
        name: title,
        description: description,
        url: canonicalURL.href,
        publisher: {
            "@type": "Organization",
            name: "KBM Security",
            url: "https://www.kbmsecurity.com.br",
        },
        ...(type === "article" && publishDate
            ? { datePublished: publishDate.toISOString() }
            : {}),
        ...(ogImage ? { image: ogImage.href } : {}),
    })}
/>
