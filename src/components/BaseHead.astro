---
interface Props {
    title: string;
    description: string;
    image?: string;
    type?: "website" | "article";
    publishDate?: Date;
    modifiedDate?: Date;
    tags?: string[];
    category?: string;
    readingTime?: number;
    noIndex?: boolean;
}

const {
    title,
    description,
    image,
    type = "website",
    publishDate,
    modifiedDate,
    tags,
    category,
    readingTime,
    noIndex = false,
} = Astro.props;

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = "r3d/ops — KBM Security";
const ogImage = image
    ? new URL(image.startsWith("/") ? image : `/${image}`, Astro.site)
    : null;

const umamiId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const clarityId = import.meta.env.PUBLIC_CLARITY_ID;
const gaId = import.meta.env.PUBLIC_GA_ID;

const baseKeywords = "red team, pentest, offensive security, hacking, OSINT, privilege escalation, evasion, lateral movement, KBM Security";
const pageKeywords = tags?.length
    ? `${tags.join(", ")}, ${baseKeywords}`
    : baseKeywords;
---

<!-- Charset & Viewport -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />

<!-- Favicon (SVG only — safest cross-browser approach for static sites) -->
<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- Theme -->
<meta name="theme-color" content="#0a0a0a" />
<meta name="color-scheme" content="dark" />

<!-- Primary SEO -->
<title>{title}</title>
<meta name="description" content={description} />
<meta
    name="keywords"
    content={pageKeywords}
/>
<meta name="author" content="KBM Security" />
<meta name="robots" content={noIndex ? "noindex, follow" : "index, follow"} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{ogImage && <meta property="og:image" content={ogImage} />}
{ogImage && <meta property="og:image:alt" content={title} />}
{ogImage && <meta property="og:image:width" content="1200" />}
{ogImage && <meta property="og:image:height" content="630" />}
{ogImage && <meta property="og:image:type" content="image/png" />}
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="pt_BR" />
{
    type === "article" && publishDate && (
        <meta
            property="article:published_time"
            content={publishDate.toISOString()}
        />
    )
}
{
    type === "article" && tags?.map((tag) => (
        <meta property="article:tag" content={tag} />
    ))
}
{
    type === "article" && category && (
        <meta property="article:section" content={category} />
    )
}
{
    type === "article" && modifiedDate && (
        <meta
            property="article:modified_time"
            content={modifiedDate.toISOString()}
        />
    )
}

<!-- Twitter / X -->
<meta
    name="twitter:card"
    content={ogImage ? "summary_large_image" : "summary"}
/>
<meta name="twitter:site" content="@kbmsecurity" />
<meta name="twitter:creator" content="@kbmsecurity" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

<!-- RSS Feed -->
<link
    rel="alternate"
    type="application/rss+xml"
    title={`${siteName} RSS Feed`}
    href={`${base}feed.xml`}
/>

<!-- Fonts are now self-hosted and imported in BaseLayout.astro -->

<!-- Structured data -->
<script
    type="application/ld+json"
    set:html={JSON.stringify(
        type === "article"
            ? {
                  "@context": "https://schema.org",
                  "@type": "TechArticle",
                  headline: title,
                  description: description,
                  url: canonicalURL.href,
                  datePublished: publishDate?.toISOString(),
                  dateModified: (modifiedDate ?? publishDate)?.toISOString(),
                  inLanguage: "pt-BR",
                  keywords: tags?.join(", "),
                  articleSection: category,
                  timeRequired: readingTime ? `PT${readingTime}M` : undefined,
                  image: ogImage?.href,
                  author: {
                      "@type": "Organization",
                      name: "KBM Security",
                      url: "https://www.kbmsecurity.com.br",
                  },
                  publisher: {
                      "@type": "Organization",
                      name: "KBM Security",
                      url: "https://www.kbmsecurity.com.br",
                      logo: {
                          "@type": "ImageObject",
                          url: new URL(`${base}favicon.svg`, Astro.site).href,
                      },
                  },
                  mainEntityOfPage: {
                      "@type": "WebPage",
                      "@id": canonicalURL.href,
                  },
              }
            : {
                  "@context": "https://schema.org",
                  "@type": "WebSite",
                  name: siteName,
                  url: Astro.site?.href,
                  potentialAction: {
                      "@type": "SearchAction",
                      target: {
                          "@type": "EntryPoint",
                          urlTemplate: `${Astro.site?.href}blog/?q={search_term_string}`,
                      },
                      "query-input": "required name=search_term_string",
                  },
              },
    )}
/>

{umamiId && (
  <script
    defer
    src="https://analytics.umami.is/script.js"
    data-website-id={umamiId}
  />
)}

{clarityId && (
  <script set:html={`
    (function(c,l,a,r,i,t,y){
      c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "${clarityId}");
  `} />
)}

{gaId && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
    <script set:html={`
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '${gaId}');
    `} />
  </>
)}
