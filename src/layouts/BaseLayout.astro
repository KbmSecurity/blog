---
import BaseHead from '../components/BaseHead.astro';
import TopNav from '../components/TopNav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { translations } from '../i18n/translations';

// Serialise at build time so the inline script carries no module imports
const i18nJSON = JSON.stringify(translations);

import "@fontsource/jetbrains-mono/300.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/400-italic.css";
import "@fontsource/jetbrains-mono/500.css";
import "@fontsource/jetbrains-mono/700.css";

interface Props {
  title: string;
  titleEn?: string;
  description: string;
  descriptionEn?: string;
  image?: string;
  type?: 'website' | 'article';
  publishDate?: Date;
  modifiedDate?: Date;
  tags?: string[];
  category?: string;
  readingTime?: number;
  class?: string;
  noIndex?: boolean;
}

const {
  title,
  titleEn,
  description,
  descriptionEn,
  image,
  type = 'website',
  publishDate,
  modifiedDate,
  tags,
  category,
  readingTime,
  class: className = '',
  noIndex = false,
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="dark">
  <head>
    <script is:inline>
      (function() {
        const lang = localStorage.getItem('kbm-lang') || 'pt';
        document.documentElement.setAttribute('data-lang', lang);
      })();
    </script>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      publishDate={publishDate}
      modifiedDate={modifiedDate}
      tags={tags}
      category={category}
      readingTime={readingTime}
      noIndex={noIndex}
    />

  <!-- Hidden element carrying per-page PT/EN title+description for applyTranslations() -->
  {(titleEn || descriptionEn) && (
    <span
      id="page-i18n"
      hidden
      aria-hidden="true"
      data-title-pt={title}
      data-title-en={titleEn ?? title}
      data-desc-pt={description}
      data-desc-en={descriptionEn ?? description}
    />
  )}
  </head>


  <body class={`bg-term-bg text-term-text font-mono antialiased min-h-screen flex flex-col ${className}`}>

    <!-- Fixed top navigation -->
    <TopNav />

    <!-- Main content area -->
    <main class="flex-1 w-full">
      <slot />
    </main>

    <!-- Footer -->
    <Footer />

    <!-- Global: inject copy buttons + lang labels into all code blocks -->
    <script>
      function initCodeBlocks() {
        document.querySelectorAll('pre').forEach((pre) => {
          // Avoid double-initializing
          if (pre.dataset.initialized) return;
          pre.dataset.initialized = 'true';

          const code = pre.querySelector('code');

          // ── Detect language ─────────────────────────────────────────
          let lang = pre.dataset.language;
          if (!lang && code) {
            const langClass = [...code.classList].find((c) =>
              c.startsWith('language-')
            );
            if (langClass) lang = langClass.replace('language-', '');
          }

          // ── Detect filename from first comment line (e.g. "# foo.sh") ──
          let filename = '';
          if (code) {
            const firstLine = (code.textContent ?? '').split('\n')[0].trim();
            const fnMatch = firstLine.match(/^(?:#|\/\/)\s*([\w.\-/]+\.\w+)\s*$/);
            if (fnMatch) filename = fnMatch[1];
          }

          // ── Build wrapper ───────────────────────────────────────────
          const wrapper = document.createElement('div');
          wrapper.className = 'code-block-wrapper';

          // ── Build header ────────────────────────────────────────────
          const header = document.createElement('div');
          header.className = 'code-header';

          // Left: dots + filename
          const leftGroup = document.createElement('div');
          leftGroup.className = 'code-header-left';

          const dots = document.createElement('div');
          dots.className = 'code-dots';
          dots.innerHTML = '<span class="dot-red"></span><span class="dot-yellow"></span><span class="dot-green"></span>';
          leftGroup.appendChild(dots);

          const filenameEl = document.createElement('span');
          filenameEl.className = 'code-filename';
          filenameEl.textContent = filename;
          leftGroup.appendChild(filenameEl);
          header.appendChild(leftGroup);

          // Right: lang badge + copy button group
          const rightGroup = document.createElement('div');
          rightGroup.className = 'code-header-right';

          if (lang && lang !== 'text' && lang !== 'plaintext') {
            const badge = document.createElement('span');
            badge.className = 'code-lang';
            badge.textContent = lang.toUpperCase();
            rightGroup.appendChild(badge);
          }

          const btn = document.createElement('button');
          btn.textContent = 'copiar';
          btn.className = 'copy-btn';
          btn.setAttribute('aria-label', 'Copiar código para área de transferência');

          btn.addEventListener('click', async () => {
            const text = code?.textContent ?? pre.textContent ?? '';
            try {
              await navigator.clipboard.writeText(text);
              btn.textContent = '✓ copiado';
              btn.classList.add('copied');
              setTimeout(() => {
                btn.textContent = 'copiar';
                btn.classList.remove('copied');
              }, 2000);
            } catch {
              btn.textContent = 'erro';
              setTimeout(() => {
                btn.textContent = 'copiar';
              }, 2000);
            }
          });

          rightGroup.appendChild(btn);
          header.appendChild(rightGroup);

          // Insert wrapper around the pre
          pre.parentNode?.insertBefore(wrapper, pre);
          wrapper.appendChild(header);
          wrapper.appendChild(pre);
        });
      }

      // Run on load
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCodeBlocks);
      } else {
        initCodeBlocks();
      }
    </script>

    <!-- ── i18n: apply translations on load & expose global helper ───── -->
    <script define:vars={{ i18nJSON }}>
      (function () {
        const T = JSON.parse(i18nJSON);

        /**
         * Loops all [data-i18n] elements and sets their textContent from the
         * translations map for the given lang ('pt' | 'en').
         *
         * Elements that carry `data-i18n-html` as well use innerHTML instead
         * (useful for strings with inline markup like <a> tags).
         */
        function applyTranslations(lang) {
          const map = T[lang] || T['pt'];
          document.querySelectorAll('[data-i18n]').forEach(function (el) {
            const key = el.getAttribute('data-i18n');
            if (key && map[key] !== undefined) {
              if (el.hasAttribute('data-i18n-html')) {
                el.innerHTML = map[key];
              } else {
                el.textContent = map[key];
              }
            }
          });

          // ── Swap page <title> and <meta name="description"> ──────────────
          const pageMeta = document.getElementById('page-i18n');
          if (pageMeta) {
            const newTitle = pageMeta.getAttribute('data-title-' + lang);
            const newDesc  = pageMeta.getAttribute('data-desc-'  + lang);
            if (newTitle) document.title = newTitle;
            const metaDesc = document.querySelector('meta[name="description"]');
            if (metaDesc && newDesc) metaDesc.setAttribute('content', newDesc);
          }

          // Update <html lang> for accessibility
          document.documentElement.lang = lang === 'pt' ? 'pt-BR' : 'en';
        }

        // Expose globally so ToggleLang.tsx can call it
        window.applyTranslations = applyTranslations;

        // Apply on first load using stored preference
        const stored = localStorage.getItem('kbm-lang') || 'pt';
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function () {
            applyTranslations(stored);
          });
        } else {
          applyTranslations(stored);
        }
      })();
    </script>

    <!-- Smooth page entry animation -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        document.body.style.opacity = '0';
        document.body.style.transition = 'opacity 0.2s ease';
        requestAnimationFrame(() => {
          document.body.style.opacity = '1';
        });
      });
    </script>

  </body>
</html>
